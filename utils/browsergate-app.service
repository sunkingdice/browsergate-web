[Unit]
Description=BrowserGate SvelteKit App
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/home/deploy/browsergate/site/app
ExecStart=/usr/bin/node --env-file=../.env build/index.js
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production
Environment=PORT=3000

[Install]
WantedBy=multi-user.target
